{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM"]
  },
  "include": [
    "vitest.config.ts",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "services/**/*.ts",
    "workers/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
